; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="speedrunner"
run/main_scene="uid://mjmvkohey8gg"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://da3gommlp1620"

[autoload]

Clock="*uid://detofq5o5147f"
Dynamics="*uid://coy2xkvb1j6fc"
RoomManager="*uid://m1qtpa83ht7f"
AudioManager="*uid://brg5fpoii7sj3"
PaletteManager="*uid://cqm0100lh1gyr"
Globals="*uid://df7q381pq6pf0"
SaveManager="*uid://ylocb765ycdw"
SettingsManager="*uid://8mb8rxyrwayn"

[display]

window/size/viewport_width=320
window/size/viewport_height=240
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/godot_super-wakatime/plugin.cfg")

